# OS / filesystem
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Editors / IDEs
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.history/
.fleet/
.zed/

# Local env / secrets — language-level .gitignore catches dist/build,
# this catches anything dropped at the workspace root.
.env
.env.*
!.env.example
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build / tool caches that any package could create
.cache/
.turbo/
.parcel-cache/
.eslintcache
.tsbuildinfo
*.tsbuildinfo

# Coverage artifacts (each package also ignores its own)
coverage/
*.lcov
