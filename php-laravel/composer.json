{
    "name": "rerout/laravel",
    "description": "Laravel integration for the Rerout branded-link API — service provider, facade, config, webhook controller, and events.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "rerout",
        "laravel",
        "short-links",
        "url-shortener",
        "qr-codes",
        "branded-links",
        "webhooks"
    ],
    "homepage": "https://rerout.co",
    "support": {
        "issues": "https://github.com/ModestNerds-Co/rerout-sdks/issues",
        "source": "https://github.com/ModestNerds-Co/rerout-sdks"
    },
    "authors": [
        {
            "name": "Codecraft Solutions",
            "email": "hello@codecraftsolutions.co.za",
            "homepage": "https://codecraftsolutions.co.za"
        }
    ],
    "require": {
        "php": "^8.2",
        "rerout/sdk": "^0.2 || ^0.3",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rerout\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rerout\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rerout\\Laravel\\ReroutServiceProvider"
            ],
            "aliases": {
                "Rerout": "Rerout\\Laravel\\Facades\\Rerout"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "format": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
