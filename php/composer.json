{
    "name": "rerout/sdk",
    "description": "Official PHP SDK for the Rerout branded-link API.",
    "type": "library",
    "version": "0.1.0",
    "license": "MIT",
    "keywords": [
        "rerout",
        "short-links",
        "url-shortener",
        "qr-codes",
        "branded-links",
        "sdk"
    ],
    "homepage": "https://rerout.co",
    "support": {
        "issues": "https://github.com/ModestNerds-Co/rerout-sdks/issues",
        "source": "https://github.com/ModestNerds-Co/rerout-sdks"
    },
    "authors": [
        {
            "name": "Codecraft Solutions",
            "email": "hello@codecraftsolutions.co.za",
            "homepage": "https://codecraftsolutions.co.za"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-hash": "*",
        "guzzlehttp/guzzle": "^7.5",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rerout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rerout\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
